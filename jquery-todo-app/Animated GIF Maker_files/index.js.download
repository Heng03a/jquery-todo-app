// stage content:
(lib.html5_b2b_meeting_planner_sep_en_300x250 = function(mode,startPosition,loop,reversed) {
if (loop == null) { loop = true; }
if (reversed == null) { reversed = false; }
	var props = new Object();
	props.mode = mode;
	props.startPosition = startPosition;
	props.labels = {};
	props.loop = loop;
	props.reversed = reversed;
	cjs.MovieClip.apply(this,[props]);

	// logo
	this.instance = new lib.logo();

	this.timeline.addTween(cjs.Tween.get(this.instance).wait(175));

	// maskbtm (mask)
	var mask = new cjs.Shape();
	mask._off = true;
	var mask_graphics_66 = new cjs.Graphics().p("A1UDXIAAmtMAqpAAAIAAGtg");

	this.timeline.addTween(cjs.Tween.get(mask).to({graphics:null,x:0,y:0}).wait(66).to({graphics:mask_graphics_66,x:150,y:170.55}).wait(109));

	// cta2
	this.instance_1 = new lib.Tween15("synched",0);
	this.instance_1.setTransform(150,105);
	this.instance_1._off = true;

	this.instance_2 = new lib.Tween16("synched",0);
	this.instance_2.setTransform(150,125);

	var maskedShapeInstanceList = [this.instance_1,this.instance_2];

	for(var shapedInstanceItr = 0; shapedInstanceItr < maskedShapeInstanceList.length; shapedInstanceItr++) {
		maskedShapeInstanceList[shapedInstanceItr].mask = mask;
	}

	this.timeline.addTween(cjs.Tween.get({}).to({state:[]}).to({state:[{t:this.instance_1}]},66).to({state:[{t:this.instance_2}]},20).wait(89));
	this.timeline.addTween(cjs.Tween.get(this.instance_1).wait(66).to({_off:false},0).to({_off:true,y:125},20,cjs.Ease.quadInOut).wait(89));

	// masktop (mask)
	var mask_1 = new cjs.Shape();
	mask_1._off = true;
	var mask_1_graphics_64 = new cjs.Graphics().p("A1UDXIAAmtMAqpAAAIAAGtg");

	this.timeline.addTween(cjs.Tween.get(mask_1).to({graphics:null,x:0,y:0}).wait(64).to({graphics:mask_1_graphics_64,x:150,y:127.55}).wait(111));

	// cta1
	this.instance_3 = new lib.Tween13("synched",0);
	this.instance_3.setTransform(150,145);
	this.instance_3._off = true;

	this.instance_4 = new lib.Tween14("synched",0);
	this.instance_4.setTransform(150,125);

	var maskedShapeInstanceList = [this.instance_3,this.instance_4];

	for(var shapedInstanceItr = 0; shapedInstanceItr < maskedShapeInstanceList.length; shapedInstanceItr++) {
		maskedShapeInstanceList[shapedInstanceItr].mask = mask_1;
	}

	this.timeline.addTween(cjs.Tween.get({}).to({state:[]}).to({state:[{t:this.instance_3}]},64).to({state:[{t:this.instance_4}]},20).wait(91));
	this.timeline.addTween(cjs.Tween.get(this.instance_3).wait(64).to({_off:false},0).to({_off:true,y:125},20,cjs.Ease.quadInOut).wait(91));

	// box
	this.instance_5 = new lib.Tween11("synched",0);
	this.instance_5.setTransform(150,125,0.0033,1);
	this.instance_5._off = true;

	this.instance_6 = new lib.Tween12("synched",0);
	this.instance_6.setTransform(150,125);

	this.timeline.addTween(cjs.Tween.get({}).to({state:[]}).to({state:[{t:this.instance_5}]},54).to({state:[{t:this.instance_6}]},26).wait(95));
	this.timeline.addTween(cjs.Tween.get(this.instance_5).wait(54).to({_off:false},0).to({_off:true,scaleX:1},26,cjs.Ease.quadInOut).wait(95));

	// head2
	this.instance_7 = new lib.Tween5("synched",0);
	this.instance_7.setTransform(150,135);
	this.instance_7.alpha = 0;
	this.instance_7._off = true;

	this.instance_8 = new lib.Tween6("synched",0);
	this.instance_8.setTransform(150,125);

	this.timeline.addTween(cjs.Tween.get({}).to({state:[]}).to({state:[{t:this.instance_7}]},19).to({state:[{t:this.instance_8}]},20).wait(136));
	this.timeline.addTween(cjs.Tween.get(this.instance_7).wait(19).to({_off:false},0).to({_off:true,y:125,alpha:1},20,cjs.Ease.quadInOut).wait(136));

	// head1
	this.instance_9 = new lib.Tween3("synched",0);
	this.instance_9.setTransform(150,115);
	this.instance_9.alpha = 0;

	this.instance_10 = new lib.Tween4("synched",0);
	this.instance_10.setTransform(150,125);

	this.timeline.addTween(cjs.Tween.get({}).to({state:[{t:this.instance_9}]}).to({state:[{t:this.instance_10}]},29).wait(146));
	this.timeline.addTween(cjs.Tween.get(this.instance_9).to({_off:true,y:125,alpha:1},29,cjs.Ease.quadInOut).wait(146));

	// img
	this.instance_11 = new lib.Tween1("synched",0);
	this.instance_11.setTransform(150,125,1.1,1.1);

	this.instance_12 = new lib.Tween2("synched",0);
	this.instance_12.setTransform(150,125);

	this.timeline.addTween(cjs.Tween.get({}).to({state:[{t:this.instance_11}]}).to({state:[{t:this.instance_12}]},105).wait(70));
	this.timeline.addTween(cjs.Tween.get(this.instance_11).to({_off:true,scaleX:1,scaleY:1},105).wait(70));

	this._renderFirstFrame();

}).prototype = p = new lib.AnMovieClip();
